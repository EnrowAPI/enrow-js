{
  "name": "enrow",
  "version": "1.0.0",
  "description": "Official Node.js/TypeScript SDK for the Enrow API — find and verify professional emails and phone numbers",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "enrow",
    "email-finder",
    "email-verifier",
    "phone-finder",
    "email",
    "api",
    "sdk"
  ],
  "author": "Enrow",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/EnrowAPI/enrow-js"
  },
  "homepage": "https://docs.enrow.io",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
